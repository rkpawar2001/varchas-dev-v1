{% schema %}
{
  "name": "Varchas Announcement",
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text",
          "default": "🔥 Free Shipping on Orders Above ₹999 · New Drop: Kurukshetra Collection Live Now →"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Varchas Announcement",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}

{% if section.blocks.size > 0 %}
<div class="bar">
  {% for block in section.blocks %}
    {% if block.settings.link != blank %}
      <a href="{{ block.settings.link }}" style="color: inherit; text-decoration: none;">{{ block.settings.text }}</a>
    {% else %}
      <span>{{ block.settings.text }}</span>
    {% endif %}
    {% if forloop.last == false %} &nbsp;&nbsp;&nbsp; {% endif %}
  {% endfor %}
</div>
{% endif %}
