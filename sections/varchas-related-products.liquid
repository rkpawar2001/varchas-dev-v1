{% schema %}
{
  "name": "Related Products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Discover More" },
    { "type": "html", "id": "headline", "label": "Headline", "default": "YOUR LINEAGE<br>CONTINUES" }
  ],
  "presets": [
    { "name": "Varchas Related Products" }
  ]
}
{% endschema %}

<!-- 
  We use Shopify's standard dynamic product recommendations endpoint.
  We are wrapping it in a custom element <product-recommendations> that will fetch the HTML via AJAX.
-->
<product-recommendations
  class="related-section"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=4"
>
  {% if recommendations.performed %}
    {% if recommendations.products_count > 0 %}
      {% assign related_items = recommendations.products %}
    {% else %}
      {% assign related_items = collections.all.products %}
    {% endif %}

    {% if related_items.size > 0 %}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="stitle">{{ section.settings.headline }}</h2>
      <div class="related-grid">
        {% for related in related_items limit: 4 %}
        <div class="rel-card rel-{{ forloop.index | modulo: 4 | plus: 1 }}" onclick="location.href='{{ related.url }}'">
          <div class="rel-img">
            <div class="rel-bg"></div>
            <div class="rel-mock" style="position:relative; z-index:2; height:100%; display:flex; align-items:center; justify-content:center;">
              {% if related.featured_image %}
                <img src="{{ related.featured_image | image_url: width: 400 }}" alt="{{ related.title | escape }}" style="max-height:80%; object-fit:contain;" loading="lazy" width="400" height="auto">
              {% else %}
                <div class="rel-gfx">{{ related.title | escape }}</div>
              {% endif %}
            </div>
            <!-- The form interacts with the new varchas-custom.js AJAX cart via the pdpForm structure or standard submit -->
             <form action="{{ routes.cart_add_url }}" method="post" onclick="event.stopPropagation();" class="rel-add-form">
               <input type="hidden" name="id" value="{{ related.variants.first.id }}">
               <button type="button" class="rel-add" onclick="
                 if(window.VARCHAS_CART && typeof window.VARCHAS_CART.submitForm === 'function') {
                   window.VARCHAS_CART.submitForm(this.closest('form'), this);
                 } else {
                   this.closest('form').submit();
                 }
               ">+ Add for {{ related.price | money }}</button>
             </form>
          </div>
          <div class="rel-info">
            <div class="rel-name">{{ related.title }}</div>
            <div class="rel-price">{{ related.price | money }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
    {% endif %}
  {% endif %}
</product-recommendations>

<script>
  class ProductRecommendations extends HTMLElement {
    constructor() {
      super();
    }
    connectedCallback() {
      const handleIntersection = (entries, observer) => {
        if (!entries[0].isIntersecting) return;
        observer.unobserve(this);
        fetch(this.dataset.url)
          .then(response => response.text())
          .then(text => {
            const html = document.createElement('div');
            html.innerHTML = text;
            const recommendations = html.querySelector('product-recommendations');
            if (recommendations && recommendations.innerHTML.trim().length) {
              this.innerHTML = recommendations.innerHTML;
            }
          })
          .catch(e => {
            console.error(e);
          });
      }
      new IntersectionObserver(handleIntersection.bind(this), {rootMargin: '0px 0px 400px 0px'}).observe(this);
    }
  }
  customElements.define('product-recommendations', ProductRecommendations);
</script>
