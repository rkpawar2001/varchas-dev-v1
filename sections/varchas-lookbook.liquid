{% schema %}
{
  "name": "Varchas Lookbook",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "@varchas.in" },
    { "type": "html", "id": "headline", "label": "Headline", "default": "THE LOOK<br>IN THE WILD" },
    { "type": "text", "id": "link_text", "label": "Link Text", "default": "Follow on Instagram →" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Lookbook Image",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "bg_class", "label": "Background Class (lb1 - lb5)", "default": "lb1" },
        { "type": "text", "id": "deva_text", "label": "Devanagari Background Text", "default": "अर्जुन" },
        { "type": "text", "id": "hover_text", "label": "Hover Text", "default": "View Post" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    { "name": "Varchas Lookbook", "blocks": [ {"type":"image","settings":{"bg_class":"lb1","deva_text":"अर्जुन"}}, {"type":"image","settings":{"bg_class":"lb2","deva_text":"राम"}}, {"type":"image","settings":{"bg_class":"lb3","deva_text":"धर्म"}}, {"type":"image","settings":{"bg_class":"lb4","deva_text":"वीर"}}, {"type":"image","settings":{"bg_class":"lb5","deva_text":"भारत"}} ] }
  ]
}
{% endschema %}

<section class="sec sec-dk">
  <div class="sh">
    <div><div class="eyebrow">{{ section.settings.eyebrow }}</div><h2 class="stitle">{{ section.settings.headline }}</h2></div>
    {% if section.settings.link_url != blank %}
      <a href="{{ section.settings.link_url }}" class="slnk" target="_blank">{{ section.settings.link_text }}</a>
    {% endif %}
  </div>
  <div class="lbgrid">
    {% for block in section.blocks %}
      <div class="lbi {{ block.settings.bg_class }}" onclick="{% if block.settings.link_url != blank %}window.open('{{ block.settings.link_url }}','_blank'){% endif %}">
        <div class="lbbg"></div>
        <div class="lbdeva" aria-hidden="true">{{ block.settings.deva_text }}</div>
        <div class="lbov"><span>{{ block.settings.hover_text }}</span></div>
      </div>
    {% endfor %}
  </div>
</section>
