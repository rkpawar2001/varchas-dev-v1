<!-- ═══ CART OVERLAY + SIDEBAR ═══ -->
<div class="cart-overlay" id="cartOverlay" onclick="if(window.VARCHAS_CART) VARCHAS_CART.closeSidebar()"></div>
<aside class="cart-sidebar" id="cartSidebar" aria-label="Shopping cart">
  <div class="cart-head">
    <div>
      <div class="cart-head-title">YOUR CART</div>
      <div class="cart-head-sub" id="cartItemLabel">0 Items</div>
    </div>
    <button class="cart-close" id="cartClose" aria-label="Close cart" onclick="if(window.VARCHAS_CART) VARCHAS_CART.closeSidebar()">✕</button>
  </div>
  
  <div class="cart-body" id="cartBody">
    <div class="cart-shipping-bar">
      <div class="shipping-label">Add <span id="shippingLeft">₹999</span> more for FREE shipping <svg width="14" height="14" style="vertical-align:middle;margin-left:4px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg></div>
      <div class="shipping-track"><div class="shipping-fill" id="shippingFill" style="width:0%"></div></div>
    </div>
    
    <!-- Rendered Dynamically by varchas-custom.js -->
    <div class="cart-items" id="cartItems"></div>
    
    <div class="cart-empty" id="cartEmpty">
      <div class="ce-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--saffron)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg></div>
      <div class="ce-title">YOUR CART AWAITS</div>
      <div class="ce-sub">Add something worthy of your lineage.</div>
      <button class="ce-cta" onclick="if(window.VARCHAS_CART) VARCHAS_CART.closeSidebar(); window.location.href='{{ routes.all_products_collection_url }}';">Shop the Drop →</button>
    </div>
  </div>

  <div class="cart-foot" id="cartFoot" style="display:none;">
    <div class="cart-subtotal">
      <div class="cst-label">Subtotal</div>
      <div class="cst-amount" id="cartTotal">₹ 0</div>
    </div>
    <div class="cart-tax-note">Taxes &amp; shipping calculated at checkout</div>
    
    <form action="{{ routes.cart_url }}" method="post" id="cartSidebarForm">
      <button type="submit" name="checkout" class="btn-checkout">Proceed to Checkout →</button>
    </form>
    
    <div class="cart-trust">
      <div class="ct-item"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="ct-svg" stroke="currentColor" stroke-width="2.2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg> Secure</div>
      <div class="ct-item"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="ct-svg" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M12 5l7 7-7 7"/></svg> Free Returns</div>
      <div class="ct-item"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="ct-svg" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Ships 48hrs</div>
    </div>
  </div>
</aside>
